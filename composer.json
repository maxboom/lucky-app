{
    "name": "lucky/app",
    "description": "Lucky App - test assignment",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "symfony/http-foundation": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/twig-bridge": "^7.0",
        "twig/twig": "^3.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:8000 -t src/UI/public src/UI/public/index.php"
    }
}
